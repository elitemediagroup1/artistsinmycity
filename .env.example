# ArtistsInMyCity production environment placeholders
# Add these in Netlify Site Settings > Environment variables. Never commit real secrets.

SITE_URL=https://artistsinmycity.com
NODE_VERSION=20

# Clerk auth
CLERK_PUBLISHABLE_KEY=pk_live_placeholder
CLERK_SECRET_KEY=sk_live_placeholder
CLERK_WEBHOOK_SECRET=whsec_placeholder

# Neon Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/artistsinmycity?sslmode=require
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/artistsinmycity?sslmode=require

# Claude / Anthropic AI Studio
ANTHROPIC_API_KEY=sk-ant-placeholder
CLAUDE_MODEL=claude-sonnet-4-5

# Stripe payments
STRIPE_SECRET_KEY=sk_live_placeholder
STRIPE_PUBLISHABLE_KEY=pk_live_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_ARTIST_PLAN_PRICE_ID=price_placeholder
STRIPE_FEATURED_SLOT_PRICE_ID=price_placeholder

# Media storage: choose Cloudinary or S3/R2
CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder
R2_ACCOUNT_ID=placeholder
R2_ACCESS_KEY_ID=placeholder
R2_SECRET_ACCESS_KEY=placeholder
R2_BUCKET=artistsinmycity-media

# GitHub publish/versioning
GITHUB_TOKEN=ghp_placeholder
GITHUB_OWNER=your-org
GITHUB_REPO=artistsinmycity
GITHUB_BRANCH=main

# Netlify deploy previews / rollback
NETLIFY_AUTH_TOKEN=nfp_placeholder
NETLIFY_SITE_ID=placeholder
NETLIFY_DEPLOY_HOOK_URL=https://api.netlify.com/build_hooks/placeholder

# EMG Loop webhook
LOOP_WEBHOOK_URL=https://your-loop-api.example.com/webhooks/artistsinmycity
LOOP_WEBHOOK_SECRET=placeholder
LOOP_PLATFORM_ID=artistsinmycity

# IndexNow
INDEXNOW_KEY=placeholder-indexnow-key
INDEXNOW_KEY_LOCATION=https://artistsinmycity.com/placeholder-indexnow-key.txt
INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow

# Analytics placeholders
GA4_MEASUREMENT_ID=G-PLACEHOLDER
GOOGLE_TAG_MANAGER_ID=GTM-PLACEHOLDER
MICROSOFT_CLARITY_ID=PLACEHOLDER
META_PIXEL_ID=PLACEHOLDER
TIKTOK_PIXEL_ID=PLACEHOLDER
